/* app.wxss — 全局样式 */

/* === CSS 变量 === */
page {
  --primary: #FF6B35;
  --primary-light: #FF8C60;
  --primary-dark: #E55A2B;
  --primary-bg: #FFF5F0;
  --success: #07C160;
  --warning: #FFB300;
  --danger: #FA5151;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-muted: #999999;
  --text-placeholder: #CCCCCC;
  --bg-page: #F5F5F5;
  --bg-white: #FFFFFF;
  --border-color: #EEEEEE;
  --border-radius: 12rpx;
  --shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  --shadow-large: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  background-color: var(--bg-page);
  box-sizing: border-box;
}

/* === 通用布局 === */
.container {
  min-height: 100vh;
  padding-bottom: 20rpx;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-1 {
  flex: 1;
}

/* === 间距 === */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }

/* === 文字 === */
.text-primary { color: var(--primary); }
.text-secondary { color: var(--text-secondary); }
.text-muted { color: var(--text-muted); }
.text-sm { font-size: 24rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.text-bold { font-weight: bold; }
.text-center { text-align: center; }

/* === 价格 === */
.price {
  color: var(--primary);
  font-weight: bold;
}
.price::before {
  content: '¥';
  font-size: 70%;
}

/* === 按钮 === */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 500;
  padding: 0 40rpx;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: #fff;
}

.btn-primary:active {
  background: var(--primary-dark);
}

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
}

.btn-sm {
  height: 56rpx;
  font-size: 24rpx;
  padding: 0 24rpx;
  border-radius: 28rpx;
}

.btn-block {
  width: 100%;
}

/* === 卡片 === */
.card {
  background: var(--bg-white);
  border-radius: var(--border-radius);
  padding: 24rpx;
  margin: 16rpx 24rpx;
  box-shadow: var(--shadow);
}

/* === 标签/徽章 === */
.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  border-radius: 18rpx;
  font-size: 22rpx;
  background-color: var(--primary);
  color: #fff;
}

.badge-dot {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background-color: var(--danger);
  color: #fff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* === 分隔线 === */
.divider {
  height: 1rpx;
  background-color: var(--border-color);
  margin: 16rpx 0;
}

/* === 安全区域底部 === */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* === 空状态 === */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}
.empty-state .empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}
.empty-state .empty-text {
  font-size: 28rpx;
  color: var(--text-muted);
}

/* === 菜品图片占位（按分类色系） === */
.food-image {
  width: 100%;
  height: 100%;
  border-radius: inherit;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}
.food-image::after {
  content: '';
  position: absolute;
  bottom: -20%;
  right: -20%;
  width: 80%;
  height: 80%;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
}
.food-image-text {
  font-size: 52rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.85);
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  z-index: 1;
}

/* 分类色系：招牌热菜(1) - 暖橙红 */
.cat-bg-1 { background: linear-gradient(135deg, #FF6B35, #FF8C60); }
/* 分类色系：爽口凉菜(2) - 清新绿 */
.cat-bg-2 { background: linear-gradient(135deg, #4CAF50, #81C784); }
/* 分类色系：滋补汤品(3) - 琥珀金 */
.cat-bg-3 { background: linear-gradient(135deg, #FF9800, #FFB74D); }
/* 分类色系：主食小吃(4) - 麦色棕 */
.cat-bg-4 { background: linear-gradient(135deg, #8D6E63, #BCAAA4); }
/* 分类色系：酒水饮品(5) - 清爽蓝 */
.cat-bg-5 { background: linear-gradient(135deg, #42A5F5, #90CAF9); }
