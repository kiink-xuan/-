/* pages/order-detail/order-detail.wxss */
.page { min-height: 100vh; background-color: #f5f5f5; }
.card { background: #fff; border-radius: 20rpx; padding: 28rpx; margin: 20rpx 24rpx; }
.divider { height: 1rpx; background: #f0f0f0; margin: 16rpx 0; }

/* ===== 状态头部 ===== */
.status-header {
  display: flex; flex-direction: column; align-items: center;
  padding: 50rpx 24rpx 36rpx;
}
.status-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.status-text { font-size: 38rpx; font-weight: bold; margin-bottom: 8rpx; }
.status-desc { font-size: 24rpx; color: #999; }

/* ===== 进度条 ===== */
.progress-track {
  width: 100%; height: 8rpx; background: #eee; border-radius: 4rpx;
  margin-bottom: 24rpx; overflow: hidden;
}
.progress-fill {
  height: 100%; background: linear-gradient(90deg, #FF6B35, #FF8C60);
  border-radius: 4rpx; transition: width 0.5s ease;
}
.progress-steps {
  display: flex; justify-content: space-between;
}
.progress-step {
  display: flex; flex-direction: column; align-items: center; flex: 1;
}
.step-dot {
  width: 52rpx; height: 52rpx; border-radius: 50%;
  background: #eee; display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; color: #999; font-weight: bold; margin-bottom: 10rpx;
}
.progress-step.done .step-dot { background: #FF6B35; color: #fff; }
.progress-step.current .step-dot {
  background: #fff; border: 4rpx solid #FF6B35; color: #FF6B35;
}
.step-text { font-size: 22rpx; }

/* ===== 信息网格 ===== */
.info-grid { display: flex; flex-wrap: wrap; }
.info-cell { width: 50%; margin-bottom: 20rpx; }
.info-cell-label { font-size: 24rpx; color: #999; display: block; margin-bottom: 6rpx; }
.info-cell-value { font-size: 28rpx; color: #333; font-weight: 500; }
.order-no-text { font-size: 22rpx; word-break: break-all; }
.remark-box {
  background: #FFFBF0; border-radius: 10rpx; padding: 16rpx 20rpx;
  font-size: 26rpx; color: #666; display: flex; margin-top: 8rpx;
}
.remark-label { flex-shrink: 0; }

/* ===== 菜品清单 ===== */
.section-title { font-size: 30rpx; font-weight: bold; color: #333; margin-bottom: 16rpx; }
.dish-row { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f8f8f8; }
.dish-row:last-child { border-bottom: none; }
.dish-row-img {
  width: 60rpx; height: 60rpx; border-radius: 10rpx; overflow: hidden; flex-shrink: 0; margin-right: 16rpx;
}
.dish-row-info { flex: 1; }
.dish-row-name { font-size: 28rpx; color: #333; display: block; }
.dish-row-spec { font-size: 24rpx; color: #999; display: block; }
.dish-row-qty { font-size: 26rpx; color: #999; margin: 0 16rpx; }
.dish-row-price { font-size: 28rpx; font-weight: bold; color: #333; }
.total-row { display: flex; justify-content: flex-end; align-items: baseline; gap: 12rpx; }
.total-label { font-size: 26rpx; color: #666; }
.total-price { font-size: 38rpx; font-weight: bold; color: #FF6B35; }

/* ===== 操作按钮 ===== */
.action-btns { padding: 16rpx 24rpx; display: flex; gap: 20rpx; flex-wrap: wrap; }
.action-btn {
  flex: 1; min-width: 200rpx; padding: 22rpx 0; border-radius: 40rpx;
  font-size: 28rpx; font-weight: 500; text-align: center;
}
.urge-btn { background: #FFF5F0; color: #FF6B35; border: 2rpx solid #FFE0D0; }
.done-btn { background: #F0FFF4; color: #07C160; border: 2rpx solid #D0FFE0; }
.reorder-btn { background: linear-gradient(135deg, #FF6B35, #FF8C60); color: #fff; }

/* ===== 空状态 ===== */
.empty-state { display: flex; flex-direction: column; align-items: center; padding-top: 200rpx; }
.empty-icon { font-size: 140rpx; margin-bottom: 30rpx; }
.empty-text { font-size: 32rpx; color: #666; }
