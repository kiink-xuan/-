<!--pages/order-detail/order-detail.wxml — 订单详情-->
<view class="page">
  <view wx:if="{{order}}" class="container">
    <!-- 订单状态头部 -->
    <view class="status-header" style="background: linear-gradient(135deg, {{statusInfo.color}}15, {{statusInfo.color}}30)">
      <text class="status-icon">{{statusInfo.icon}}</text>
      <text class="status-text" style="color: {{statusInfo.color}}">{{statusInfo.text}}</text>
      <text class="status-desc">{{statusDesc}}</text>
    </view>

    <!-- 进度条 -->
    <view class="card progress-card">
      <view class="progress-bar">
        <view class="progress-track">
          <view class="progress-fill" style="width: {{statusInfo.step * 33.33}}%"></view>
        </view>
        <view class="progress-steps">
          <view wx:for="{{steps}}" wx:key="step" class="progress-step {{item.step <= statusInfo.step ? 'done' : ''}} {{item.step === statusInfo.step ? 'current' : ''}}">
            <view class="step-dot">
              <text wx:if="{{item.step < statusInfo.step}}">✓</text>
              <text wx:elif="{{item.step === statusInfo.step}}">{{item.icon}}</text>
              <text wx:else>{{item.step + 1}}</text>
            </view>
            <text class="step-text" style="color: {{item.step <= statusInfo.step ? '#FF6B35' : '#ccc'}}">{{item.label}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 用餐信息 -->
    <view class="card">
      <view class="info-grid">
        <view class="info-cell">
          <text class="info-cell-label">桌号</text>
          <text class="info-cell-value">{{order.tableNo || '未设置'}}</text>
        </view>
        <view class="info-cell">
          <text class="info-cell-label">人数</text>
          <text class="info-cell-value">{{order.guestCount}}人</text>
        </view>
        <view class="info-cell">
          <text class="info-cell-label">下单时间</text>
          <text class="info-cell-value">{{order.createTime}}</text>
        </view>
        <view class="info-cell">
          <text class="info-cell-label">订单号</text>
          <text class="info-cell-value order-no-text">{{order.id}}</text>
        </view>
      </view>
      <view wx:if="{{order.remark}}" class="remark-box">
        <text class="remark-label">📝 备注：</text>
        <text>{{order.remark}}</text>
      </view>
    </view>

    <!-- 菜品清单 -->
    <view class="card">
      <view class="section-title">菜品清单</view>
      <view wx:for="{{order.items}}" wx:key="key" class="dish-row">
        <text class="dish-row-image">{{item.dish.image}}</text>
        <view class="dish-row-info">
          <text class="dish-row-name">{{item.dish.name}}</text>
          <text wx:if="{{item.spec}}" class="dish-row-spec">{{item.spec}}</text>
        </view>
        <text class="dish-row-qty">x{{item.count}}</text>
        <text class="dish-row-price">¥{{item.dish.price * item.count}}</text>
      </view>
      <view class="divider"></view>
      <view class="total-row">
        <text class="total-label">实付金额</text>
        <text class="total-price">¥{{order.totalPrice}}</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-btns">
      <view wx:if="{{order.status === 'pending' || order.status === 'cooking'}}" class="action-btn urge-btn" bindtap="onUrge">
        <text>🔔 催单</text>
      </view>
      <view wx:if="{{order.status !== 'done'}}" class="action-btn done-btn" bindtap="onMarkDone">
        <text>✅ 确认完成</text>
      </view>
      <view class="action-btn reorder-btn" bindtap="onReorder">
        <text>🔄 再来一单</text>
      </view>
    </view>

    <view style="height: 60rpx;"></view>
  </view>

  <!-- 未找到 -->
  <view wx:else class="empty-state">
    <text class="empty-icon">😕</text>
    <text class="empty-text">订单不存在</text>
  </view>
</view>
