<!--pages/index/index.wxml — 菜单浏览首页-->
<view class="page">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrapper">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索菜品..."
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        confirm-type="search"
        bindconfirm="onSearch"
      />
      <text
        wx:if="{{searchKeyword}}"
        class="search-clear"
        bindtap="onClearSearch"
      >✕</text>
    </view>
  </view>

  <!-- 主体：左侧分类 + 右侧菜品 -->
  <view class="main-content">
    <!-- 左侧分类栏 -->
    <scroll-view class="category-sidebar" scroll-y enhanced show-scrollbar="{{false}}">
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="category-item {{currentCategoryId === item.id ? 'active' : ''}}"
        data-id="{{item.id}}"
        bindtap="onSwitchCategory"
      >
        <text class="category-icon">{{item.icon}}</text>
        <text class="category-name">{{item.name}}</text>
        <view wx:if="{{currentCategoryId === item.id}}" class="category-indicator"></view>
      </view>
    </scroll-view>

    <!-- 右侧菜品列表 -->
    <scroll-view
      class="dish-list-panel"
      scroll-y
      enhanced
      show-scrollbar="{{false}}"
      scroll-into-view="{{scrollToCategory}}"
      bindscroll="onDishScroll"
    >
      <view wx:for="{{filteredDishes}}" wx:key="id" class="dish-card" bindtap="onDishTap" data-dish="{{item}}">
        <!-- 菜品图片（用 emoji 代替） -->
        <view class="dish-image-wrap">
          <text class="dish-image">{{item.image}}</text>
          <view wx:if="{{item.recommend}}" class="dish-recommend-tag">推荐</view>
        </view>

        <!-- 菜品信息 -->
        <view class="dish-info">
          <view class="dish-name-row">
            <text class="dish-name">{{item.name}}</text>
            <view wx:if="{{item.tags && item.tags.length}}" class="dish-tags">
              <text wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag" class="dish-tag">{{tag}}</text>
            </view>
          </view>
          <text class="dish-desc">{{item.desc.substring(0, 30)}}...</text>
          <view class="dish-bottom">
            <view class="dish-price-row">
              <text class="dish-price">¥{{item.price}}</text>
              <text wx:if="{{item.originalPrice}}" class="dish-original-price">¥{{item.originalPrice}}</text>
            </view>
            <text class="dish-sales">月售{{item.sales}}</text>
          </view>

          <!-- 加购按钮 -->
          <view class="dish-add-btn {{item.specs && item.specs.length ? 'has-specs' : ''}}"
                catchtap="onAddToCart" data-dish="{{item}}">
            <text class="add-icon">+</text>
          </view>
        </view>
      </view>

      <!-- 底部占位（给购物车浮栏留空间） -->
      <view style="height: 140rpx;"></view>
    </scroll-view>
  </view>

  <!-- 底部购物车浮栏 -->
  <view class="cart-float-bar {{cartTotalCount > 0 ? 'has-items' : ''}}" bindtap="onGoToCart">
    <view class="cart-float-left">
      <view class="cart-float-icon-wrap">
        <text class="cart-float-icon">🛒</text>
        <view wx:if="{{cartTotalCount > 0}}" class="cart-float-badge">{{cartTotalCount}}</view>
      </view>
      <view class="cart-float-info">
        <text wx:if="{{cartTotalCount > 0}}" class="cart-float-price">¥{{cartTotalPrice}}</text>
        <text wx:else class="cart-float-empty">购物车空空如也~</text>
        <text wx:if="{{cartTotalCount > 0}}" class="cart-float-tip">预估配送约30分钟</text>
      </view>
    </view>
    <view class="cart-float-right {{cartTotalCount > 0 ? 'active' : ''}}">
      <text wx:if="{{cartTotalCount > 0}}">去结算</text>
      <text wx:else>未选菜品</text>
    </view>
  </view>
</view>
