/* pages/order-confirm/order-confirm.wxss */
.page { min-height: 100vh; background-color: #f5f5f5; }
.card { background: #fff; border-radius: 20rpx; padding: 28rpx; margin: 20rpx 24rpx; }
.section-title { font-size: 30rpx; font-weight: bold; color: #333; margin-bottom: 24rpx; padding-bottom: 16rpx; border-bottom: 1rpx solid #f0f0f0; }

/* ===== 用餐信息 ===== */
.info-row { display: flex; align-items: center; justify-content: space-between; padding: 16rpx 0; }
.info-row:last-child { padding-bottom: 0; }
.info-row-label { font-size: 28rpx; color: #333; font-weight: 500; }
.info-row-right { display: flex; align-items: center; gap: 16rpx; }
.guest-btn {
  width: 48rpx; height: 48rpx; border-radius: 50%; border: 2rpx solid #ddd;
  display: flex; align-items: center; justify-content: center;
}
.guest-btn text { font-size: 32rpx; color: #666; }
.guest-btn.disabled { opacity: 0.4; }
.guest-value { font-size: 30rpx; font-weight: bold; color: #333; min-width: 72rpx; text-align: center; }
.info-row-input { text-align: right; font-size: 26rpx; color: #333; flex: 1; }

/* ===== 订单明细 ===== */
.order-item {
  display: flex; align-items: center; padding: 20rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}
.order-item:last-child { border-bottom: none; }
.order-item-image { font-size: 44rpx; margin-right: 16rpx; }
.order-item-info { flex: 1; }
.order-item-name { font-size: 28rpx; color: #333; display: block; }
.order-item-spec { font-size: 24rpx; color: #999; display: block; }
.order-item-count { font-size: 26rpx; color: #999; margin: 0 16rpx; }
.order-item-price { font-size: 28rpx; font-weight: bold; color: #333; }

/* ===== 价格汇总 ===== */
.price-row { display: flex; justify-content: space-between; padding: 12rpx 0; font-size: 26rpx; color: #666; }
.price-value { color: #333; }
.price-total-row { border-top: 1rpx solid #f0f0f0; padding-top: 20rpx; margin-top: 8rpx; }
.price-total-label { font-size: 30rpx; font-weight: bold; color: #333; }
.price-total-value { font-size: 36rpx; font-weight: bold; color: #FF6B35; }

/* ===== 提交栏 ===== */
.submit-bar {
  position: fixed; bottom: 0; left: 0; right: 0; background: #fff;
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 28rpx; z-index: 100;
  padding-bottom: calc(16rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.08);
}
.submit-info { display: flex; align-items: baseline; gap: 8rpx; }
.submit-label { font-size: 26rpx; color: #666; }
.submit-price { font-size: 40rpx; font-weight: bold; color: #FF6B35; }
.submit-btn {
  background: linear-gradient(135deg, #FF6B35, #FF8C60); color: #fff;
  font-size: 32rpx; font-weight: 500; padding: 20rpx 50rpx; border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(255,107,53,0.4);
}
.submit-btn:active { opacity: 0.9; }
