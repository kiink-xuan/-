/* pages/mine/mine.wxss */
.page { min-height: 100vh; background-color: #f5f5f5; }

/* ===== 用户头部 ===== */
.user-header {
  position: relative;
  margin-bottom: 20rpx;
  overflow: hidden;
}
.user-bg {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(160deg, #FF6B35 0%, #FF8C60 60%, #FFB088 100%);
}
.user-bg::after {
  content: '';
  position: absolute;
  bottom: -40rpx; left: -20%; right: -20%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 50% 50% 0 0;
}
.user-content {
  position: relative; z-index: 1;
  display: flex; align-items: center;
  padding: 56rpx 36rpx 64rpx;
}
.avatar-wrap {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: rgba(255,255,255,0.3);
  display: flex; align-items: center; justify-content: center;
  border: 4rpx solid rgba(255,255,255,0.6);
  flex-shrink: 0;
}
.avatar-text { font-size: 56rpx; }
.avatar-img {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.6);
  flex-shrink: 0;
}
.user-info { flex: 1; margin-left: 24rpx; }
.user-name {
  font-size: 36rpx; font-weight: bold; color: #fff;
  display: block; margin-bottom: 8rpx;
}
.user-sub { font-size: 24rpx; color: rgba(255,255,255,0.8); }
.login-btn {
  background: rgba(255,255,255,0.25); border-radius: 32rpx;
  padding: 14rpx 32rpx; border: 2rpx solid rgba(255,255,255,0.5);
}
.login-btn-text { font-size: 26rpx; color: #fff; font-weight: 500; }
.logout-btn { padding: 10rpx 24rpx; }
.logout-text { font-size: 24rpx; color: rgba(255,255,255,0.7); }

/* ===== 数据概览 ===== */
.stats-row {
  display: flex; background: #fff; margin: 0 24rpx 20rpx;
  border-radius: 20rpx; padding: 32rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.stat-item {
  flex: 1; display: flex; flex-direction: column; align-items: center;
}
.stat-item:not(:last-child) { border-right: 1rpx solid #f0f0f0; }
.stat-value { font-size: 44rpx; font-weight: bold; color: #FF6B35; margin-bottom: 8rpx; }
.stat-label { font-size: 24rpx; color: #999; }

/* ===== 功能菜单 ===== */
.menu-section {
  background: #fff; border-radius: 20rpx;
  margin: 0 24rpx 20rpx; overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.menu-title {
  font-size: 26rpx; font-weight: 600; color: #999;
  padding: 24rpx 28rpx 12rpx;
}
.menu-item {
  display: flex; align-items: center; padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f8f8f8;
  transition: background 0.15s;
}
.menu-item:active { background: #fafafa; }
.menu-item:last-child { border-bottom: none; }
.menu-icon-wrap {
  width: 56rpx; height: 56rpx; border-radius: 14rpx;
  display: flex; align-items: center; justify-content: center; margin-right: 20rpx;
}
.icon-orange { background: #FFF5F0; }
.icon-green { background: #F0FFF4; }
.icon-blue { background: #F0F5FF; }
.icon-purple { background: #F8F0FF; }
.icon-cyan { background: #F0FAFF; }
.menu-icon { font-size: 32rpx; }
.menu-text { flex: 1; font-size: 28rpx; color: #333; }
.menu-right { display: flex; align-items: center; }
.menu-badge {
  min-width: 36rpx; height: 36rpx; border-radius: 18rpx;
  background: #FA5151; color: #fff; font-size: 20rpx;
  display: flex; align-items: center; justify-content: center;
  padding: 0 8rpx; margin-right: 12rpx;
}
.menu-arrow { font-size: 36rpx; color: #ccc; }

/* ===== 关于 ===== */
.about-text { text-align: center; padding: 40rpx; }
.about-text text { font-size: 24rpx; color: #ccc; }
