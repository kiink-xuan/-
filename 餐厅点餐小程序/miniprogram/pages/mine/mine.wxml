<!--pages/mine/mine.wxml — 个人中心-->
<view class="page">
  <!-- 用户信息头部 -->
  <view class="user-header">
    <view class="user-bg"></view>
    <view class="user-content">
      <!-- 已登录：显示头像和昵称 -->
      <block wx:if="{{isLogin && userInfo}}">
        <image wx:if="{{userInfo.avatarUrl}}" class="avatar-img" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
        <view wx:else class="avatar-wrap">
          <text class="avatar-text">🧑</text>
        </view>
        <view class="user-info">
          <text class="user-name">{{userInfo.nickName}}</text>
          <text class="user-sub">欢迎来到好味道餐厅</text>
        </view>
        <view class="logout-btn" bindtap="onLogout">
          <text class="logout-text">退出</text>
        </view>
      </block>

      <!-- 未登录：显示登录入口 -->
      <block wx:else>
        <view class="avatar-wrap" bindtap="onLogin">
          <text class="avatar-text">🧑</text>
        </view>
        <view class="user-info">
          <text class="user-name">点击登录</text>
          <text class="user-sub">登录后可同步订单数据</text>
        </view>
        <view class="login-btn" bindtap="onLogin">
          <text class="login-btn-text">登录</text>
        </view>
      </block>
    </view>
  </view>

  <!-- 数据概览 -->
  <view class="stats-row">
    <view class="stat-item" bindtap="onGoOrders">
      <text class="stat-value">{{orderStats.total}}</text>
      <text class="stat-label">全部订单</text>
    </view>
    <view class="stat-item" bindtap="onGoOrders">
      <text class="stat-value" style="color: #FFB300;">{{orderStats.active}}</text>
      <text class="stat-label">进行中</text>
    </view>
    <view class="stat-item" bindtap="onGoOrders">
      <text class="stat-value" style="color: #07C160;">{{orderStats.done}}</text>
      <text class="stat-label">已完成</text>
    </view>
  </view>

  <!-- 常用功能 -->
  <view class="menu-section">
    <view class="menu-title">常用功能</view>
    <view class="menu-item" bindtap="onGoOrders">
      <view class="menu-icon-wrap icon-orange"><text class="menu-icon">📋</text></view>
      <text class="menu-text">我的订单</text>
      <view class="menu-right">
        <text wx:if="{{orderStats.active > 0}}" class="menu-badge">{{orderStats.active}}</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
    <view class="menu-item" bindtap="onGoCart">
      <view class="menu-icon-wrap icon-orange"><text class="menu-icon">🛒</text></view>
      <text class="menu-text">购物车</text>
      <view class="menu-right">
        <text wx:if="{{cartTotalCount > 0}}" class="menu-badge">{{cartTotalCount}}</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
    <view class="menu-item" bindtap="onGoMenu">
      <view class="menu-icon-wrap icon-green"><text class="menu-icon">🍽️</text></view>
      <text class="menu-text">浏览菜单</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 其他服务 -->
  <view class="menu-section">
    <view class="menu-title">其他服务</view>
    <view class="menu-item" bindtap="onContact">
      <view class="menu-icon-wrap icon-blue"><text class="menu-icon">💬</text></view>
      <text class="menu-text">联系客服</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item">
      <view class="menu-icon-wrap icon-purple"><text class="menu-icon">⭐</text></view>
      <text class="menu-text">收藏的菜品</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onAbout">
      <view class="menu-icon-wrap icon-cyan"><text class="menu-icon">ℹ️</text></view>
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 关于 -->
  <view class="about-text">
    <text>好味道餐厅 v1.0.0</text>
  </view>
</view>
