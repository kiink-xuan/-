/* pages/dish-detail/dish-detail.wxss */
.page { min-height: 100vh; background-color: #f5f5f5; }
.dish-hero {
  width: 100%; height: 400rpx;
  background: linear-gradient(135deg, #FFF5F0, #FFE8DC, #FFF0E8);
  display: flex; align-items: center; justify-content: center; position: relative;
}
.dish-hero-image { font-size: 180rpx; }
.hero-tags { position: absolute; bottom: 24rpx; left: 24rpx; display: flex; gap: 12rpx; }
.hero-tag {
  font-size: 22rpx; color: #fff; background-color: rgba(255,107,53,0.85);
  padding: 4rpx 16rpx; border-radius: 20rpx;
}
.card { background: #fff; border-radius: 20rpx; padding: 28rpx; margin: 20rpx 24rpx; }
.info-header { display: flex; align-items: center; margin-bottom: 12rpx; }
.info-name { font-size: 38rpx; font-weight: bold; color: #333; margin-right: 16rpx; }
.recommend-badge {
  background: linear-gradient(135deg, #FFD700, #FFA500);
  color: #fff; font-size: 20rpx; padding: 4rpx 14rpx; border-radius: 20rpx;
}
.info-desc { font-size: 26rpx; color: #666; line-height: 1.7; margin-bottom: 20rpx; }
.info-stats { display: flex; align-items: baseline; gap: 12rpx; }
.info-price { font-size: 44rpx; font-weight: bold; color: #FF6B35; }
.info-original-price { font-size: 26rpx; color: #bbb; text-decoration: line-through; }
.info-sales { font-size: 24rpx; color: #999; }
.info-discount { font-size: 22rpx; color: #fff; background-color: #FA5151; padding: 2rpx 12rpx; border-radius: 10rpx; }
.spec-group { margin-bottom: 24rpx; }
.spec-group:last-child { margin-bottom: 0; }
.spec-label { font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 16rpx; display: block; }
.spec-options { display: flex; flex-wrap: wrap; gap: 16rpx; }
.spec-option {
  padding: 12rpx 28rpx; border-radius: 10rpx; font-size: 26rpx; color: #666;
  background-color: #f5f5f5; border: 2rpx solid transparent; transition: all 0.2s;
}
.spec-option.active { color: #FF6B35; background-color: #FFF5F0; border-color: #FF6B35; font-weight: 500; }
.qty-row { display: flex; align-items: center; justify-content: space-between; }
.qty-label { font-size: 28rpx; font-weight: 600; color: #333; }
.qty-control { display: flex; align-items: center; gap: 28rpx; }
.qty-btn {
  width: 52rpx; height: 52rpx; border-radius: 50%; background-color: #FF6B35;
  display: flex; align-items: center; justify-content: center; transition: all 0.15s;
}
.qty-btn text { font-size: 36rpx; color: #fff; line-height: 1; }
.qty-btn.disabled { background-color: #ddd; }
.qty-btn:active:not(.disabled) { transform: scale(0.9); }
.qty-value { font-size: 34rpx; font-weight: bold; color: #333; min-width: 48rpx; text-align: center; }
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0; background: #fff;
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 24rpx; z-index: 100;
  padding-bottom: calc(16rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.08);
}
.bottom-bar-left { display: flex; align-items: center; position: relative; }
.bottom-cart-icon { font-size: 44rpx; margin-right: 12rpx; }
.bottom-cart-badge {
  position: absolute; top: -8rpx; left: 30rpx; min-width: 34rpx; height: 34rpx;
  border-radius: 17rpx; background-color: #FA5151; color: #fff; font-size: 20rpx;
  display: flex; align-items: center; justify-content: center; padding: 0 8rpx;
}
.bottom-cart-price { font-size: 32rpx; font-weight: bold; color: #FF6B35; }
.bottom-bar-right { display: flex; gap: 20rpx; }
.btn-add-cart {
  background: linear-gradient(135deg, #FF6B35, #FF8C60); color: #fff;
  font-size: 30rpx; font-weight: 500; padding: 20rpx 56rpx; border-radius: 44rpx;
  box-shadow: 0 4rpx 16rpx rgba(255,107,53,0.4);
}
.btn-add-cart:active { opacity: 0.9; transform: scale(0.98); }
