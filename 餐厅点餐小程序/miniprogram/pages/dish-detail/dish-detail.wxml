<!--pages/dish-detail/dish-detail.wxml — 菜品详情-->
<view class="page">
  <view wx:if="{{dish}}" class="container">
    <!-- 菜品大图 -->
    <view class="dish-hero cat-bg-{{dish.categoryId}}">
      <text class="dish-hero-text">{{dish.name[0]}}</text>
      <view wx:if="{{dish.tags && dish.tags.length}}" class="hero-tags">
        <text wx:for="{{dish.tags}}" wx:key="*this" class="hero-tag">{{item}}</text>
      </view>
    </view>

    <!-- 基本信息 -->
    <view class="card info-card">
      <view class="info-header">
        <text class="info-name">{{dish.name}}</text>
        <view wx:if="{{dish.recommend}}" class="recommend-badge">🌟 主厨推荐</view>
      </view>
      <text class="info-desc">{{dish.desc}}</text>
      <view class="info-stats">
        <text class="info-price">¥{{dish.price}}</text>
        <text wx:if="{{dish.originalPrice}}" class="info-original-price">¥{{dish.originalPrice}}</text>
        <text class="info-sales">月售 {{dish.sales}} 份</text>
        <text wx:if="{{dish.originalPrice}}" class="info-discount">省¥{{dish.originalPrice - dish.price}}</text>
      </view>
    </view>

    <!-- 规格选择 -->
    <view wx:if="{{dish.specs && dish.specs.length > 0}}" class="card spec-card">
      <view wx:for="{{dish.specs}}" wx:key="name" wx:for-item="spec" class="spec-group">
        <text class="spec-label">{{spec.name}}</text>
        <view class="spec-options">
          <view
            wx:for="{{spec.options}}"
            wx:key="*this"
            wx:for-item="option"
            class="spec-option {{selectedSpecs[spec.name] === option ? 'active' : ''}}"
            data-spec-name="{{spec.name}}"
            data-option="{{option}}"
            bindtap="onSelectSpec"
          >{{option}}</view>
        </view>
      </view>
    </view>

    <!-- 购买数量 -->
    <view class="card qty-card">
      <view class="qty-row">
        <text class="qty-label">购买数量</text>
        <view class="qty-control">
          <view class="qty-btn {{quantity <= 1 ? 'disabled' : ''}}" catchtap="onDecrease"><text>-</text></view>
          <text class="qty-value">{{quantity}}</text>
          <view class="qty-btn" catchtap="onIncrease"><text>+</text></view>
        </view>
      </view>
    </view>

    <view style="height: 180rpx;"></view>
  </view>

  <!-- 底部操作栏 -->
  <view wx:if="{{dish}}" class="bottom-bar">
    <view class="bottom-bar-left" bindtap="onPreviewCart">
      <text class="bottom-cart-icon">🛒</text>
      <view wx:if="{{cartTotalCount > 0}}" class="bottom-cart-badge">{{cartTotalCount}}</view>
      <text class="bottom-cart-price" wx:if="{{cartTotalPrice > 0}}">¥{{cartTotalPrice}}</text>
    </view>
    <view class="bottom-bar-right">
      <view class="btn-add-cart" bindtap="onAddToCart"><text>加入购物车</text></view>
    </view>
  </view>

  <!-- 未找到菜品 -->
  <view wx:else class="empty-state">
    <text class="empty-icon">😕</text>
    <text class="empty-text">菜品不存在或已下架</text>
  </view>
</view>
