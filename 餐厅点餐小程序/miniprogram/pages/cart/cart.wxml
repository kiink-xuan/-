<!--pages/cart/cart.wxml — 购物车-->
<view class="page">
  <!-- 购物车列表 -->
  <view wx:if="{{cartList.length > 0}}" class="container">
    <!-- 顶部分类提示 -->
    <view class="cart-header">
      <text class="cart-header-icon">🛒</text>
      <text class="cart-header-text">共 {{cartTotalCount}} 件商品</text>
      <view class="cart-header-right" bindtap="onClearCart">
        <text class="clear-text">清空</text>
      </view>
    </view>

    <!-- 购物车列表 -->
    <view class="cart-list">
      <view wx:for="{{cartList}}" wx:key="key" class="cart-item">
        <!-- 菜品图片 -->
        <view class="cart-item-image-wrap">
          <text class="cart-item-image">{{item.dish.image}}</text>
        </view>

        <!-- 菜品信息 -->
        <view class="cart-item-info">
          <text class="cart-item-name">{{item.dish.name}}</text>
          <text wx:if="{{item.spec}}" class="cart-item-spec">{{item.spec}}</text>
          <view class="cart-item-bottom">
            <text class="cart-item-price">¥{{item.dish.price}}</text>
            <!-- 数量控制 -->
            <view class="cart-qty-control">
              <view class="cart-qty-btn" catchtap="onDecrease" data-key="{{item.key}}">
                <text>-</text>
              </view>
              <text class="cart-qty-value">{{item.count}}</text>
              <view class="cart-qty-btn" catchtap="onIncrease" data-key="{{item.key}}">
                <text>+</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 备注区 -->
    <view class="remark-card">
      <text class="remark-label">订单备注</text>
      <input class="remark-input" placeholder="口味、忌口等特殊要求..." value="{{remark}}" bindinput="onRemarkInput" />
    </view>

    <!-- 底部占位 -->
    <view style="height: 160rpx;"></view>
  </view>

  <!-- 空购物车 -->
  <view wx:else class="empty-state">
    <text class="empty-icon">🛒</text>
    <text class="empty-text">购物车空空如也</text>
    <text class="empty-sub">快去菜单看看吧～</text>
    <view class="empty-btn" bindtap="onGoMenu">
      <text>去点餐</text>
    </view>
  </view>

  <!-- 底部结算栏 -->
  <view wx:if="{{cartList.length > 0}}" class="settle-bar">
    <view class="settle-left">
      <text class="settle-total-label">合计：</text>
      <text class="settle-total-price">¥{{cartTotalPrice}}</text>
    </view>
    <view class="settle-right" bindtap="onCheckout">
      <text>去结算</text>
    </view>
  </view>
</view>
