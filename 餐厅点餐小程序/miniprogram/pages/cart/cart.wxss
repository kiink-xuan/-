/* pages/cart/cart.wxss */
.page { min-height: 100vh; background-color: #f5f5f5; }

/* ===== 头部 ===== */
.cart-header {
  display: flex; align-items: center; padding: 24rpx 28rpx;
  background: #fff; margin-bottom: 16rpx;
}
.cart-header-icon { font-size: 36rpx; margin-right: 12rpx; }
.cart-header-text { flex: 1; font-size: 28rpx; color: #333; font-weight: 500; }
.cart-header-right { padding: 8rpx 20rpx; }
.clear-text { font-size: 26rpx; color: #999; }

/* ===== 列表 ===== */
.cart-list { background: #fff; }
.cart-item {
  display: flex; padding: 24rpx 28rpx; border-bottom: 1rpx solid #f5f5f5;
  align-items: center;
}
.cart-item:last-child { border-bottom: none; }
.cart-item-image-wrap {
  width: 120rpx; height: 120rpx; border-radius: 14rpx;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  overflow: hidden;
}
.cart-food-text { font-size: 40rpx; }
.cart-item-info { flex: 1; margin-left: 20rpx; }
.cart-item-name { font-size: 30rpx; font-weight: 600; color: #333; display: block; margin-bottom: 6rpx; }
.cart-item-spec { font-size: 24rpx; color: #999; display: block; margin-bottom: 12rpx; }
.cart-item-bottom { display: flex; align-items: center; justify-content: space-between; }
.cart-item-price { font-size: 32rpx; font-weight: bold; color: #FF6B35; }
.cart-qty-control { display: flex; align-items: center; gap: 20rpx; }
.cart-qty-btn {
  width: 44rpx; height: 44rpx; border-radius: 50%; border: 2rpx solid #ddd;
  display: flex; align-items: center; justify-content: center;
}
.cart-qty-btn text { font-size: 30rpx; color: #666; line-height: 1; }
.cart-qty-value { font-size: 28rpx; font-weight: bold; color: #333; min-width: 40rpx; text-align: center; }

/* ===== 备注 ===== */
.remark-card {
  margin: 20rpx 0; background: #fff; padding: 24rpx 28rpx;
}
.remark-label { font-size: 28rpx; font-weight: 600; color: #333; display: block; margin-bottom: 16rpx; }
.remark-input { font-size: 26rpx; color: #333; background: #f8f8f8; padding: 12rpx 20rpx; border-radius: 10rpx; }

/* ===== 空状态 ===== */
.empty-state { display: flex; flex-direction: column; align-items: center; padding-top: 200rpx; }
.empty-icon { font-size: 140rpx; margin-bottom: 30rpx; }
.empty-text { font-size: 32rpx; color: #666; margin-bottom: 12rpx; }
.empty-sub { font-size: 26rpx; color: #999; margin-bottom: 40rpx; }
.empty-btn {
  background: linear-gradient(135deg, #FF6B35, #FF8C60); color: #fff;
  padding: 18rpx 56rpx; border-radius: 40rpx; font-size: 28rpx;
}

/* ===== 底部结算栏 ===== */
.settle-bar {
  position: fixed; bottom: 0; left: 0; right: 0; background: #fff;
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 28rpx; z-index: 100;
  padding-bottom: calc(16rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.08);
}
.settle-left { display: flex; align-items: baseline; }
.settle-total-label { font-size: 28rpx; color: #333; }
.settle-total-price { font-size: 40rpx; font-weight: bold; color: #FF6B35; }
.settle-right {
  background: linear-gradient(135deg, #FF6B35, #FF8C60); color: #fff;
  font-size: 30rpx; font-weight: 500; padding: 18rpx 50rpx; border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(255,107,53,0.4);
}
.settle-right:active { opacity: 0.9; }
